# Backend Environment Configuration
# 复制此文件为 .env 并填入实际值

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
EMBEDDING_MODEL=text2vec-base-chinese

# Cloud API (Optional - for enhanced responses)
CLOUD_API_KEY=sk-your-api-key-here
CLOUD_API_BASE=https://api.deepseek.com

# Storage Paths
NAS_MOUNT_PATH=/mnt/nas/baby_health

# Logging
LOG_LEVEL=INFO
